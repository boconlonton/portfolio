# Backend origin (no trailing slash). Required for chat to send: `${NEXT_PUBLIC_BACKEND_URL}/api/agent/chat`.
# If unset, the chat sheet still opens but Send is disabled (tooltip: coming soon).
# NEXT_PUBLIC_BACKEND_URL=https://api.example.com

# Used only on the backend that implements `/api/agent/chat`, not by `pnpm build` for the static site.
# OPENAI_API_KEY=

# Cognito — auth page (/auth). Required for sign in / register to work.
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_COGNITO_REGION=us-east-1

# Cognito Hosted UI domain — required for Google OAuth (no trailing slash, no https://).
# Format: <your-prefix>.auth.<region>.amazoncognito.com
# NEXT_PUBLIC_COGNITO_DOMAIN=my-app.auth.us-east-1.amazoncognito.com

# OAuth callback URL — must be registered in Cognito App Client "Allowed callback URLs".
# For local dev use http://localhost:3000/auth/callback; for prod use the deployed URL.
# NEXT_PUBLIC_COGNITO_REDIRECT_URI=https://limitisthesky.dev/auth/callback
